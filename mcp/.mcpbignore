# TypeScript source — only the compiled `server/` directory needs to ship.
src/
tsconfig.json
*.tsbuildinfo

# Build artefacts and dev metadata that the bundle doesn't need.
# Anchor to the project root so we don't accidentally exclude `dist`
# directories nested inside `node_modules/` (the @modelcontextprotocol/sdk
# package, for one, ships its runtime as dist/esm and dist/cjs).
/dist/
.DS_Store
*.log
