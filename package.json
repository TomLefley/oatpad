{
  "name": "oatpad",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "predev": "node -e \"if(!require('fs').existsSync('mcp/dist/oatpad.mcpb'))process.exit(1)\" || npm run build:mcpb",
    "build": "tauri build",
    "dev:web": "vite",
    "build:web": "vite build",
    "build:mcpb": "cd mcp && npm install && npm run pack",
    "build:bundle-prereqs": "npm run build:web && npm run build:mcpb",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/dompurify": "^3.0.5",
    "@types/turndown": "^5.0.6",
    "jsdom": "^29.1.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@lucide/svelte": "^1.8.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "dompurify": "^3.4.1",
    "quill": "^2.0.2",
    "turndown": "^7.2.0"
  }
}
